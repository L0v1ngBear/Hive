.search-bar {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 10;
}
.search-bar input {
  flex: 1;
  background: #f0f2f5;
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
  margin: 0 20rpx;
  font-size: 26rpx;
}
.add-mini-btn {
  font-size: 24rpx;
  background: #07c160;
  color: #fff;
  padding: 0 20rpx;
  line-height: 60rpx;
}
.customer-card {
  background: #fff;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}
.company-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}
.customer-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-left: 15rpx;
}
.blue { background: #e6f7ff; color: #1890ff; }
.orange { background: #fff7e6; color: #fa8c16; }
.info-row {
  margin-top: 15rpx;
  font-size: 26rpx;
  color: #666;
}