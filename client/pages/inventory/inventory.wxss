/* pages/inventory/inventory.wxss */
page {
  background-color: #fafafa;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  padding-top: env(safe-area-inset-top);
  box-sizing: border-box;
  height: 100vh;
  overflow: hidden;
}

/* 滚动容器 */
.scroll-container {
  width: 100%;
  height: 100%;
  scrollbar-width: none;
  -ms-overflow-style: none;
}
.scroll-container::-webkit-scrollbar {
  display: none;
}

/* 根容器：贴屏且保留统一空隙 */
.container {
  width: 100%;
  padding: 0 12px;
  padding-bottom: 30px;
  box-sizing: border-box;
}

/* 顶部导航：与内容块左对齐 */
.top-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 0;
  margin-bottom: 16px;
  width: calc(100% - 24px);
  margin-left: auto;
  margin-right: auto;
}
.nav-back {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.2s ease;
}
.nav-back-hover, .nav-back:active {
  background-color: #f5f5f5;
  transform: scale(0.95);
}
.back-icon {
  width: calc(100vw / 375 * 40); /* 从20改为24，比例放大 */
  height: calc(100vw / 375 * 40); /* 保持宽高一致，避免变形 */
}
.nav-title {
  font-size: 18px;
  font-weight: 600;
  color: #333;
}
.nav-scan {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.2s ease;
}
.nav-scan-hover, .nav-scan:active {
  background-color: #f5f5f5;
  transform: scale(0.95);
}
.scan-icon {
  width: 20px;
  height: 20px;
}

/* 统一内容块样式 */
.inventory-overview, .quick-actions, .record-section {
  width: 100%;
  border-radius: 16px;
  box-shadow: 0 2px 12px rgba(245, 166, 35, 0.06);
  margin-bottom: 16px;
  box-sizing: border-box;
}

/* 库存概览卡片 */
.inventory-overview {
  background: linear-gradient(180deg, #ffffff 0%, #FFFCF8 100%);
  padding: 24px 20px;
}
.overview-title {
  font-size: 18px;
  font-weight: 600;
  color: #333;
  margin-bottom: 20px;
}
.overview-stats {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.stat-item {
  text-align: center;
  flex: 1;
}
.stat-label {
  font-size: 16px;
  color: #666;
  display: block;
  margin-bottom: 8px;
}
.stat-value {
  font-size: 24px;
  font-weight: 600;
  color: #333;
}
.in-stock {
  color: #52C41A;
}
.out-stock {
  color: #F5222D;
}

/* 快捷操作区 */
.quick-actions {
  background-color: #fff;
  padding: 20px;
  display: flex;
  justify-content: space-around;
}
.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 80px;
  height: 80px;
  transition: all 0.2s ease;
}
.action-item-hover, .action-item:active {
  transform: scale(0.95);
  opacity: 0.8;
}
.action-icon {
  width: 36px;
  height: 36px;
  margin-bottom: 8px;
}
.action-text {
  font-size: 16px;
  color: #333;
}

/* 操作记录区域 */
.record-section {
  background-color: #fff;
  padding: 20px;
}
.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}
.section-title text:first-child {
  font-size: 18px;
  font-weight: 600;
  color: #333;
}
.record-more {
  font-size: 16px;
  color: #F5A623;
}
.record-more-hover, .record-more:active {
  opacity: 0.8;
  color: #D48806;
}

/* 记录列表 - 核心修改区域 */
.record-list {
  width: 100%;
}
.record-header {
  display: flex;
  padding: 8px 0;
  border-bottom: 1px solid #f5f5f5;
  margin-bottom: 8px;
  /* 新增：添加内边距，让内容不贴边 */
  padding-left: 4px;
  padding-right: 4px;
}
.header-col {
  font-size: 16px;
  font-weight: 600;
  color: #999;
  word-break: break-all;
  line-height: 1.2;
  display: flex;
  align-items: center;
  /* 关键修改：重新分配列宽，增加间距 */
  padding: 0 8px; /* 新增：列内边距，增加间距 */
  box-sizing: border-box;
}
/* 关键修改：调整各列宽度比例 */
.time-col {
  width: 25%;
  text-align: left;
  justify-content: flex-start;
}
.type-col {
  width: 25%; 
  text-align: center;
}
.model-col { /* 新增：专门的型号列样式 */
  width: 25%; /* 新增：足够宽的型号列 */
  text-align: center;
  justify-content: center;
}
.meter-col { /* 新增：专门的米数列样式 */
  width: 25%; /* 新增：足够宽的米数列 */
  text-align: center;
  justify-content: center;
}
/* 废弃原有多余的列样式 */
.goods-col, .count-col, .status-col {
  display: none;
}

/* 记录项 - 同步修改 */
.record-item {
  display: flex;
  padding: 12px 0;
  border-bottom: 1px solid #f9f9f9;
  /* 新增：和表头保持一致的内边距 */
  padding-left: 4px;
  padding-right: 4px;
}
.record-item:last-child {
  border-bottom: none;
}
.record-col {
  font-size: 16px;
  color: #333;
  word-break: break-all;
  line-height: 1.2;
  display: flex;
  align-items: center;
  /* 关键修改：同步列内边距 */
  padding: 0 8px;
  box-sizing: border-box;
}
/* 同步调整记录项的列宽 */
.record-col.time-col {
  width: 25%;
  text-align: left;
  justify-content: flex-start;
}
.record-col.type-col {
  width: 25%;
  text-align: center;
}
.record-col.model-col {
  width: 25%;
  text-align: left;
  justify-content: center;
}
.record-col.meter-col {
  width: 25%;
  text-align: center;
  justify-content: center;
}

.type-in {
  line-height: 0px;
  color: #52C41A;
}
.type-out {
  line-height: 0px;
  color: #F5222D;
}
.status-success {
  line-height: 0px;
  color: #52C41A;
}
.status-fail {
  line-height: 0px;
  color: #F5222D;
}

/* 空记录提示 */
.empty-record {
  padding: 32px 0;
  text-align: center;
  font-size: 16px;
  color: #999;
}

/* 阻止事件冒泡 */
.stopPropagation {
  pointer-events: auto;
}

/* 弹窗遮罩（统一） */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

/* 弹窗内容（统一） */
.modal-content {
  width: 80%;
  max-width: 400rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-sizing: border-box;
}
/* 手动入库弹窗适配（更大宽度） */
.modal-content.add-cloth-modal {
  max-width: 500rpx;
  max-height: 80vh;
  overflow-y: auto;
}

/* 弹窗标题（统一） */
.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 20rpx;
  color: #333;
}

/* 弹窗信息行（基础） */
.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  position: relative;
}
.info-row text {
  font-size: 28rpx;
  color: #666;
  min-width: 120rpx;
}
.info-row input {
  flex: 1;
  height: 70rpx;
  border: 1px solid #eee;
  border-radius: 8rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #333;
}

/* 🔥 新增：型号搜索下拉列表样式（适配原有设计） */
.model-list {
  position: absolute;
  top: 80rpx;
  left: 120rpx;
  right: 0;
  background: #fff;
  border: 1px solid #f5f5f5;
  border-radius: 12rpx;
  box-shadow: 0 4px 12px rgba(245, 166, 35, 0.08);
  max-height: 200rpx;
  overflow-y: auto;
  z-index: 1000;
}
.model-item {
  padding: 12rpx 20rpx;
  border-bottom: 1px solid #f9f9f9;
  font-size: 28rpx;
  color: #333;
  transition: all 0.2s ease;
}
.model-item:last-child {
  border-bottom: none;
}
.model-item.create-item {
  color: #F5A623; /* 适配原有主题色 */
  font-weight: 500;
}
.model-item:active {
  background-color: #fafafa;
}

/* 弹窗信息（原有） */
.modal-info {
  display: flex;
  margin-bottom: 20rpx;
  font-size: 28rpx;
}
.info-label {
  color: #666;
  width: 120rpx;
}
.info-value {
  color: #333;
  flex: 1;
  word-break: break-all;
}

/* 操作类型按钮 */
.oper-type-btns {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}
.oper-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 8rpx;
  border: none;
  color: #fff;
  font-size: 28rpx;
}
.in-btn {
  background: #07c160;
}
.out-btn {
  background: #ff4757;
}

/* 数量输入框 */
.count-input {
  width: 100%;
  height: 70rpx;
  border: 1px solid #eee;
  border-radius: 8rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

/* 弹窗操作按钮（统一） */
.modal-actions, .oper-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}
.modal-btn, .btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  border: none;
}
.cancel-btn, .btn.cancel {
  background: #f5f5f5;
  color: #666;
  line-height: 30px;
}
.confirm-btn, .btn.in {
  background: linear-gradient(90deg, #F5A623, #FFB84D); /* 适配原有主题渐变 */
  color: #fff;
  line-height: 30px;
}
.btn.out {
  background: #F5222D;
  color: #fff;
}

/* 打印弹窗样式 */
.print-type-btns {
  display: flex;
  gap: 20rpx;
  margin: 20rpx 0;
}
.print-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 8rpx;
  border: none;
  color: #fff;
  font-size: 28rpx;
}
.preview-btn {
  background: #0088ff;
}
.bluetooth-btn {
  background: #07c160;
}