/* pages/inventory/inventory.wxss */
page {
  background-color: #fafafa;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  padding-top: env(safe-area-inset-top);
  box-sizing: border-box;
  height: 100vh;
  overflow: hidden;
}

/* 滚动容器 */
.scroll-container {
  width: 100%;
  height: 100%;
  scrollbar-width: none;
  -ms-overflow-style: none;
}
.scroll-container::-webkit-scrollbar {
  display: none;
}

/* 根容器：贴屏且保留统一空隙 */
.container {
  width: 100%;
  padding: 0 12px;
  padding-bottom: 30px;
  box-sizing: border-box;
}

/* 顶部导航：与内容块左对齐 */
.top-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 0;
  margin-bottom: 16px;
  width: calc(100% - 24px);
  margin-left: auto;
  margin-right: auto;
}
.nav-back {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.2s ease;
}
.nav-back-hover, .nav-back:active {
  background-color: #f5f5f5;
  transform: scale(0.95);
}
.back-icon {
  width: calc(100vw / 375 * 40); /* 从20改为24，比例放大 */
  height: calc(100vw / 375 * 40); /* 保持宽高一致，避免变形 */
}
.nav-title {
  font-size: 18px;
  font-weight: 600;
  color: #333;
}
.nav-scan {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.2s ease;
}
.nav-scan-hover, .nav-scan:active {
  background-color: #f5f5f5;
  transform: scale(0.95);
}
.scan-icon {
  width: 20px;
  height: 20px;
}

/* 统一内容块样式 */
.inventory-overview, .quick-actions, .record-section {
  width: 100%;
  border-radius: 16px;
  box-shadow: 0 2px 12px rgba(245, 166, 35, 0.06);
  margin-bottom: 16px;
  box-sizing: border-box;
}

/* 库存概览卡片 */
.inventory-overview {
  background: linear-gradient(180deg, #ffffff 0%, #FFFCF8 100%);
  padding: 24px 20px;
}
.overview-title {
  font-size: 18px;
  font-weight: 600;
  color: #333;
  margin-bottom: 20px;
}
.overview-stats {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.stat-item {
  text-align: center;
  flex: 1;
}
.stat-label {
  font-size: 16px;
  color: #666;
  display: block;
  margin-bottom: 8px;
}
.stat-value {
  font-size: 24px;
  font-weight: 600;
  color: #333;
}
.in-stock {
  color: #52C41A;
}
.out-stock {
  color: #F5222D;
}

/* 快捷操作区 */
.quick-actions {
  background-color: #fff;
  padding: 20px;
  display: flex;
  justify-content: space-around;
}
.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 80px;
  height: 80px;
  transition: all 0.2s ease;
}
.action-item-hover, .action-item:active {
  transform: scale(0.95);
  opacity: 0.8;
}
.action-icon {
  width: 36px;
  height: 36px;
  margin-bottom: 8px;
}
.action-text {
  font-size: 16px;
  color: #333;
}

/* 操作记录区域 */
.record-section {
  background-color: #fff;
  padding: 20px;
}
.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}
.section-title text:first-child {
  font-size: 18px;
  font-weight: 600;
  color: #333;
}
.record-more {
  font-size: 16px;
  color: #F5A623;
}
.record-more-hover, .record-more:active {
  opacity: 0.8;
  color: #D48806;
}

/* 记录列表 */
.record-list {
  width: 100%;
}
.record-header {
  display: flex;
  padding: 8px 0;
  border-bottom: 1px solid #f5f5f5;
  margin-bottom: 8px;
}
.header-col {
  font-size: 16px;
  font-weight: 600;
  color: #999;
  word-break: break-all;
  line-height: 1.2;
  display: flex;
  align-items: center;
  justify-content: center;
}
.time-col {
  width: 20%;
  text-align: left;
  justify-content: flex-start;
}
.type-col {
  width: 20%;
  text-align: center;
}
.goods-col {
  width: 30%;
  text-align: center;
}
.count-col {
  width: 15%;
  text-align: center;
}
.status-col {
  width: 15%;
  text-align: center;
}

/* 记录项 */
.record-item {
  display: flex;
  padding: 12px 0;
  border-bottom: 1px solid #f9f9f9;
}
.record-item:last-child {
  border-bottom: none;
}
.record-col {
  font-size: 16px;
  color: #333;
  word-break: break-all;
  line-height: 1.2;
  display: flex;
  align-items: center;
  justify-content: center;
}
.time-col {
  width: 20%;
  text-align: left;
  justify-content: flex-start;
}
.type-in {
  line-height: 0px;
  color: #52C41A;
}
.type-out {
  line-height: 0px;
  color: #F5222D;
}
.status-success {
  line-height: 0px;
  color: #52C41A;
}
.status-fail {
  line-height: 0px;
  color: #F5222D;
}

/* 空记录提示 */
.empty-record {
  padding: 32px 0;
  text-align: center;
  font-size: 16px;
  color: #999;
}

/* 扫码弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.modal-content {
  width: 80%;
  max-width: 300px;
  background-color: #fff;
  border-radius: 16px;
  padding: 24px;
  box-sizing: border-box;
}
.modal-title {
  font-size: 18px;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 20px;
}
.modal-info {
  margin-bottom: 24px;
}
.info-label {
  font-size: 16px;
  color: #666;
}
.info-value {
  font-size: 16px;
  color: #333;
  font-weight: 500;
}
.modal-actions {
  display: flex;
  gap: 12px;
}
.modal-btn {
  flex: 1;
  height: 44px;
  line-height: 44px;
  border-radius: 8px;
  font-size: 16px;
}
.cancel-btn {
  background-color: #f5f5f5;
  color: #666;
  border: none;
}
.confirm-btn {
  background: linear-gradient(90deg, #F5A623, #FFB84D);
  color: #fff;
  border: none;
}

/* 阻止事件冒泡 */
.stopPropagation {
  pointer-events: auto;
}