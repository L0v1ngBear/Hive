/* 基础重置与全局适配 */
page {
  background-color: #fafafa;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  padding-top: env(safe-area-inset-top);
  padding-bottom: env(safe-area-inset-bottom);
  padding-left: env(safe-area-inset-left);
  padding-right: env(safe-area-inset-right);
  box-sizing: border-box;
  height: 100%;
  min-height: 100vh;
  font-size: clamp(14px, calc(100vw / 375 * 16), 18px);
}

/* 滚动容器 */
.scroll-container {
  width: 100%;
  height: calc(100vh - env(safe-area-inset-top));
  height: calc(100dvh - env(safe-area-inset-top));
  min-height: 100%;
  -webkit-overflow-scrolling: touch;
  scroll-behavior: smooth;
  scrollbar-width: none;
  -ms-overflow-style: none;
  box-sizing: border-box;
}
.scroll-container::-webkit-scrollbar {
  display: none;
}

/* 根容器 */
.container {
  width: 100%;
  padding: 0 clamp(8px, calc(100vw / 375 * 12), 20px);
  padding-bottom: clamp(20px, calc(100vw / 375 * 30), 40px);
  box-sizing: border-box;
  max-width: 480px;
  margin: 0 auto;
}

/* 顶部导航 */
.top-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: clamp(8px, calc(100vw / 375 * 12), 16px) 0;
  margin-bottom: clamp(12px, calc(100vw / 375 * 16), 20px);
  width: 100%;
  min-height: clamp(32px, calc(100vw / 375 * 36), 44px);
  box-sizing: border-box;
}
.nav-back, .nav-add {
  width: clamp(32px, calc(100vw / 375 * 36), 44px);
  height: clamp(32px, calc(100vw / 375 * 36), 44px);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.2s ease;
  flex-shrink: 0;
  touch-action: manipulation;
}
.nav-back-hover, .nav-add-hover, .nav-back:active, .nav-add:active {
  background-color: #f5f5f5;
  transform: scale(0.95);
}
.back-icon, .add-icon {
  width: clamp(16px, calc(100vw / 375 * 20), 24px);
  height: clamp(16px, calc(100vw / 375 * 20), 24px);
  max-width: 100%;
  max-height: 100%;
}
.nav-title {
  font-size: clamp(16px, calc(100vw / 375 * 18), 20px);
  font-weight: 600;
  color: #333;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin: 0 clamp(4px, calc(100vw / 375 * 8), 12px);
  flex: 1;
  text-align: center;
}

/* 筛选区 */
.defective-filter {
  width: 100%;
  margin-bottom: clamp(12px, calc(100vw / 375 * 16), 20px);
}
.filter-group {
  display: flex;
  align-items: center;
  margin-bottom: clamp(8px, calc(100vw / 375 * 12), 16px);
  flex-wrap: wrap;
  row-gap: clamp(6px, calc(100vw / 375 * 8), 10px);
}
.filter-label {
  font-size: clamp(14px, calc(100vw / 375 * 16), 18px);
  color: #666;
  min-width: clamp(48px, calc(100vw / 375 * 60), 72px);
  flex-shrink: 0;
}
.filter-items {
  display: flex;
  flex-wrap: wrap;
  gap: clamp(6px, calc(100vw / 375 * 8), 10px);
  flex: 1;
}
.filter-item {
  padding: clamp(4px, calc(100vw / 375 * 6), 8px) clamp(10px, calc(100vw / 375 * 12), 14px);
  background-color: #fff;
  border-radius: clamp(16px, calc(100vw / 375 * 20), 24px);
  font-size: clamp(14px, calc(100vw / 375 * 16), 18px);
  color: #666;
  transition: all 0.2s ease;
  box-shadow: 0 clamp(1px, calc(100vw / 375 * 2), 3px) clamp(8px, calc(100vw / 375 * 12), 16px) rgba(245, 166, 35, 0.06);
  min-width: clamp(48px, calc(100vw / 375 * 60), 72px);
  text-align: center;
  flex-shrink: 0;
  touch-action: manipulation;
}
.filter-item.active {
  background: linear-gradient(90deg, #F5A623, #FFB84D);
  color: #fff;
}
.date-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: clamp(4px, calc(100vw / 375 * 6), 8px) clamp(10px, calc(100vw / 375 * 12), 14px);
  background-color: #fff;
  border-radius: clamp(16px, calc(100vw / 375 * 20), 24px);
  font-size: clamp(14px, calc(100vw / 375 * 16), 18px);
  color: #666;
  min-width: clamp(120px, calc(100vw / 375 * 140), 160px);
  flex: 1;
}
.arrow-icon {
  width: clamp(12px, calc(100vw / 375 * 14), 16px);
  height: clamp(12px, calc(100vw / 375 * 14), 16px);
  flex-shrink: 0;
}

/* 次品列表区域 */
.defective-section {
  width: 100%;
  border-radius: clamp(12px, calc(100vw / 375 * 16), 20px);
  box-shadow: 0 clamp(1px, calc(100vw / 375 * 2), 3px) clamp(8px, calc(100vw / 375 * 12), 16px) rgba(245, 166, 35, 0.06);
  background-color: #fff;
  padding: clamp(16px, calc(100vw / 375 * 20), 24px);
  box-sizing: border-box;
  min-height: auto;
  margin: 0;
}
.defective-section.empty-section {
  padding: clamp(40px, calc(100vw / 375 * 50), 60px) 0;
  min-height: clamp(100px, calc(100vw / 375 * 120), 140px);
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 空数据提示 */
.empty-record {
  padding: 0;
  text-align: center;
  font-size: clamp(14px, calc(100vw / 375 * 16), 18px);
  color: #999;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: clamp(40px, calc(100vw / 375 * 50), 60px);
  margin: 0;
}

/* 次品卡片 */
.defective-card {
  padding: clamp(16px, calc(100vw / 375 * 20), 24px) 0;
  border-bottom: 1px solid #f9f9f9;
  box-sizing: border-box;
  touch-action: auto;
}
.defective-card:last-child {
  border-bottom: none;
}
.card-content {
  width: 100%;
}
.defective-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: clamp(12px, calc(100vw / 375 * 16), 20px);
  flex-wrap: wrap;
  row-gap: clamp(6px, calc(100vw / 375 * 8), 10px);
}
.defective-code {
  font-size: clamp(14px, calc(100vw / 375 * 16), 18px);
  color: #333;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 70%;
}
.defective-status {
  font-size: clamp(14px, calc(100vw / 375 * 16), 18px);
  padding: clamp(2px, calc(100vw / 375 * 4), 6px) clamp(6px, calc(100vw / 375 * 8), 10px);
  border-radius: clamp(6px, calc(100vw / 375 * 8), 10px);
  color: #fff;
  flex-shrink: 0;
}
.status-pending {
  background-color: #faad14;
}
.status-processed {
  background-color: #52C41A;
}

/* 信息组 */
.info-group {
  margin-bottom: clamp(12px, calc(100vw / 375 * 16), 20px);
  width: 100%;
  box-sizing: border-box;
}
.info-line {
  display: flex;
  align-items: center;
  margin-bottom: clamp(6px, calc(100vw / 375 * 8), 10px);
  font-size: clamp(14px, calc(100vw / 375 * 16), 18px);
  flex-wrap: wrap;
  row-gap: clamp(2px, calc(100vw / 375 * 4), 6px);
  column-gap: clamp(6px, calc(100vw / 375 * 8), 10px);
}
.info-label {
  color: #666;
  min-width: clamp(60px, calc(100vw / 375 * 70), 80px);
  flex-shrink: 0;
}
.info-value {
  color: #333;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: calc(100% - clamp(68px, calc(100vw / 375 * 80), 90px));
}
.ml-12 {
  margin-left: clamp(8px, calc(100vw / 375 * 12), 16px);
}

/* 次品描述 */
.desc-box {
  margin-bottom: clamp(12px, calc(100vw / 375 * 16), 20px);
}
.desc-title {
  font-size: clamp(14px, calc(100vw / 375 * 16), 18px);
  color: #666;
  display: block;
  margin-bottom: clamp(4px, calc(100vw / 375 * 6), 8px);
}
.desc-content {
  font-size: clamp(14px, calc(100vw / 375 * 16), 18px);
  color: #333;
  line-height: 1.5;
  word-wrap: break-word;
}

/* 处理状态 */
.process-status {
  display: flex;
  align-items: center;
  margin-bottom: clamp(8px, calc(100vw / 375 * 12), 16px);
}
.process-label {
  font-size: clamp(14px, calc(100vw / 375 * 16), 18px);
  color: #666;
  min-width: clamp(60px, calc(100vw / 375 * 70), 80px);
}
.process-value {
  font-size: clamp(14px, calc(100vw / 375 * 16), 18px);
}
.process-value.success {
  color: #52C41A;
}
.process-value.pending {
  color: #faad14;
}

/* 操作按钮 */
.defective-action {
  display: flex;
  justify-content: flex-end;
  gap: clamp(8px, calc(100vw / 375 * 12), 16px);
  margin-top: clamp(8px, calc(100vw / 375 * 12), 16px);
}
.edit-btn, .process-btn {
  border-radius: clamp(6px, calc(100vw / 375 * 8), 10px);
  font-size: clamp(12px, calc(100vw / 375 * 14), 16px);
  padding: clamp(4px, calc(100vw / 375 * 6), 8px) clamp(10px, calc(100vw / 375 * 12), 14px);
}
.edit-btn {
  background-color: #f5f5f5;
  color: #666;
}
.process-btn {
  background: linear-gradient(90deg, #F5A623, #FFB84D);
  color: #fff;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
  padding: env(safe-area-inset-top) env(safe-area-inset-right) env(safe-area-inset-bottom) env(safe-area-inset-left);
  box-sizing: border-box;
  min-height: 100vh;
}
.modal-content {
  width: clamp(280px, 80%, 360px);
  max-width: calc(100vw - 40px);
  background-color: #fff;
  border-radius: clamp(12px, calc(100vw / 375 * 16), 20px);
  padding: clamp(20px, calc(100vw / 375 * 24), 28px);
  box-sizing: border-box;
  min-width: 260px;
}
.modal-title {
  font-size: clamp(16px, calc(100vw / 375 * 18), 20px);
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: clamp(16px, calc(100vw / 375 * 20), 24px);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.modal-form {
  margin-bottom: clamp(20px, calc(100vw / 375 * 24), 28px);
}
.form-item {
  margin-bottom: clamp(10px, calc(100vw / 375 * 12), 14px);
  width: 100%;
}
.form-label {
  font-size: clamp(14px, calc(100vw / 375 * 16), 18px);
  color: #666;
  display: block;
  margin-bottom: clamp(4px, calc(100vw / 375 * 6), 8px);
}
/* 必填标记样式 */
.required {
  color: #ff4d4f;
  margin-left: 2px;
}
.form-input, .form-textarea {
  width: 100%;
  padding: clamp(8px, calc(100vw / 375 * 10), 12px) clamp(10px, calc(100vw / 375 * 12), 14px);
  border: 1px solid #f0f0f0;
  border-radius: clamp(6px, calc(100vw / 375 * 8), 10px);
  font-size: clamp(14px, calc(100vw / 375 * 16), 18px);
  color: #333;
  box-sizing: border-box;
}
.form-textarea {
  min-height: clamp(80px, calc(100vw / 375 * 100), 120px);
  resize: none;
  line-height: 1.5;
}
.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: clamp(8px, calc(100vw / 375 * 10), 12px) clamp(10px, calc(100vw / 375 * 12), 14px);
  border: 1px solid #f0f0f0;
  border-radius: clamp(6px, calc(100vw / 375 * 8), 10px);
  font-size: clamp(14px, calc(100vw / 375 * 16), 18px);
  color: #333;
}
.modal-info {
  margin-bottom: clamp(20px, calc(100vw / 375 * 24), 28px);
}
.info-row {
  display: flex;
  align-items: center;
  margin-bottom: clamp(10px, calc(100vw / 375 * 12), 14px);
  font-size: clamp(14px, calc(100vw / 375 * 16), 18px);
  flex-wrap: wrap;
  row-gap: clamp(2px, calc(100vw / 375 * 4), 6px);
}
.modal-actions {
  display: flex;
  gap: clamp(10px, calc(100vw / 375 * 12), 14px);
  width: 100%;
}
.modal-btn {
  flex: 1;
  height: clamp(36px, calc(100vw / 375 * 44), 48px);
  line-height: clamp(36px, calc(100vw / 375 * 44), 48px);
  border-radius: clamp(6px, calc(100vw / 375 * 8), 10px);
  font-size: clamp(14px, calc(100vw / 375 * 16), 18px);
  border: none;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  touch-action: manipulation;
}
.cancel-btn {
  background-color: #f5f5f5;
  color: #666;
}
.confirm-btn {
  background: linear-gradient(90deg, #F5A623, #FFB84D);
  color: #fff;
}

/* 通用样式 */
.stopPropagation {
  pointer-events: auto;
}

/* 小屏手机适配 (<=320px) */
@media (max-width: 320px) {
  .filter-group {
    flex-direction: column;
    align-items: flex-start;
  }
  .filter-label {
    margin-bottom: 4px;
  }
  .defective-section {
    padding: clamp(12px, calc(100vw / 375 * 16), 20px);
  }
  .defective-section.empty-section {
    padding: clamp(30px, calc(100vw / 375 * 40), 50px) 0;
    min-height: clamp(80px, calc(100vw / 375 * 100), 120px);
  }
}

/* 大屏手机适配 (>=414px) */
@media (min-width: 414px) {
  .container {
    max-width: 440px;
    margin: 0 auto;
  }
  .nav-back, .nav-add {
    width: 44px;
    height: 44px;
  }
  .defective-section.empty-section {
    padding: clamp(50px, calc(100vw / 375 * 60), 70px) 0;
    min-height: clamp(120px, calc(100vw / 375 * 140), 160px);
  }
}

/* 平板/超大屏适配 (>=768px) */
@media (min-width: 768px) {
  .container {
    max-width: 480px;
    margin: 20px auto;
  }
  page {
    display: flex;
    justify-content: center;
    background-color: #eee;
  }
  .scroll-container {
    border-radius: 20px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
    overflow: hidden;
    height: calc(100vh - 40px);
    height: calc(100dvh - 40px);
  }
  .defective-section.empty-section {
    padding: clamp(60px, calc(100vw / 375 * 70), 80px) 0;
    min-height: clamp(140px, calc(100vw / 375 * 160), 180px);
  }
}

/* 横屏适配 */
@media (orientation: landscape) {
  .scroll-container {
    height: 100vh;
    height: 100dvh;
    min-height: 100vh;
  }
  .defective-section {
    min-height: auto;
  }
  .defective-section.empty-section {
    min-height: calc(100vh - 160px);
    padding: 40px 0;
  }
  .modal-content {
    width: clamp(300px, 60%, 400px);
  }
}