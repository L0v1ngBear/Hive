<scroll-view 
  class="scroll-container" 
  scroll-y="true" 
  scroll-with-animation="true"
  enhanced="true"
  bounces="true"
>
  <view class="container">
    <!-- 顶部导航 -->
    <view class="top-nav">
      <view class="nav-back" bindtap="handleBack" hover-class="nav-back-hover">
        <image class="back-icon" src="/images/back.png" mode="widthFix" lazy-load="true"></image>
      </view>
      <text class="nav-title">次品管理</text>
      <view class="nav-add" bindtap="openAddModal" hover-class="nav-add-hover">
        <image class="add-icon" src="/images/add.png" mode="widthFix" lazy-load="true"></image>
      </view>
    </view>

    <!-- 筛选区 -->
    <view class="defective-filter">
      <!-- 状态筛选 -->
      <view class="filter-group">
        <text class="filter-label">状态：</text>
        <view class="filter-items">
          <view class="filter-item {{currentStatus==item.key?'active':''}}" wx:for="{{statusList}}" wx:key="key"
            bindtap="handleStatusFilter" data-status="{{item.key}}">
            {{item.label}}
          </view>
        </view>
      </view>

      <!-- 次品类型筛选 -->
      <view class="filter-group">
        <text class="filter-label">类型：</text>
        <view class="filter-items">
          <view class="filter-item {{currentType==item.key?'active':''}}" wx:for="{{typeList}}" wx:key="key"
            bindtap="handleTypeFilter" data-type="{{item.key}}">
            {{item.label}}
          </view>
        </view>
      </view>

      <!-- 时间筛选 -->
      <view class="filter-group">
        <text class="filter-label">时间：</text>
        <picker mode="date" value="{{dateRange}}" start="2026-01-01" end="{{currentDate}}" bindchange="handleDateFilter">
          <view class="date-picker">
            <text>{{dateRange || '全部时间'}}</text>
            <image class="arrow-icon" src="/images/arrow-down.png" mode="widthFix"></image>
          </view>
        </picker>
      </view>
    </view>

    <!-- 次品列表区域 -->
    <view class="defective-section {{filteredDefectiveList.length === 0 ? 'empty-section' : ''}}">
      <!-- 空数据提示 -->
      <view wx:if="{{filteredDefectiveList.length === 0}}" class="empty-record">
        <text>暂无相关次品数据</text>
      </view>

      <!-- 次品卡片列表 -->
      <block wx:for="{{filteredDefectiveList}}" wx:key="defectiveId">
        <view class="defective-card">
          <!-- 次品详情点击区域 -->
          <view class="card-content" bindtap="openDetail" data-defective="{{item}}">
            <view class="defective-head">
              <text class="defective-code">次品编号：{{item.defectiveId}}</text>
              <text class="defective-status {{statusClass[item.status]}}">{{statusMap[item.status]}}</text>
            </view>

            <!-- 基础信息 -->
            <view class="info-group">
              <view class="info-line">
                <text class="info-label">关联订单：</text>
                <text class="info-value">{{item.orderId || '无'}}</text>
                <text class="info-label ml-12">次品类型：</text>
                <text class="info-value">{{typeMap[item.type]}}</text>
              </view>
              <view class="info-line">
                <text class="info-label">登记时间：</text>
                <text class="info-value">{{item.createTime}}</text>
                <text class="info-label ml-12">登记人：</text>
                <text class="info-value">{{item.creator}}</text>
              </view>
              <view class="info-line">
                <text class="info-label">次品数量：</text>
                <text class="info-value">{{item.quantity}}米</text>
                <text class="info-label ml-12">损失金额：</text>
                <text class="info-value">¥{{item.lossAmount}}</text>
              </view>
            </view>

            <!-- 次品描述 -->
            <view class="desc-box">
              <text class="desc-title">次品描述：</text>
              <text class="desc-content">{{item.description || '无'}}</text>
            </view>

            <!-- 处理状态 -->
            <view class="process-status">
              <text class="process-label">处理状态：</text>
              <text class="process-value {{item.status == 'processed' ? 'success' : 'pending'}}">
                {{item.status == 'processed' ? '已处理' : '待处理'}}
              </text>
            </view>
          </view>

          <!-- 操作按钮 -->
          <view class="defective-action">
            <button class="edit-btn" size="mini" bindtap="openEditModal" data-defective="{{item}}">编辑</button>
            <button class="process-btn" size="mini" type="primary" bindtap="openProcessModal" data-defective="{{item}}" wx:if="{{item.status != 'processed'}}">标记处理</button>
          </view>
        </view>
      </block>
    </view>
  </view>
</scroll-view>

<!-- 新增/编辑次品弹窗 -->
<view class="modal-mask" wx:if="{{showAddModal}}" bindtap="closeAddModal">
  <view class="modal-content" catchtap="stopPropagation">
    <view class="modal-title">{{isEdit ? '编辑次品信息' : '新增次品登记'}}</view>
    <view class="modal-form">
      <view class="form-item">
        <text class="form-label">关联订单号：</text>
        <input class="form-input" placeholder="可选，输入关联订单号" value="{{formData.orderId}}" bindinput="handleInput" data-key="orderId"></input>
      </view>
      <view class="form-item">
        <text class="form-label">次品类型：<text class="required">*</text></text>
        <!-- 修复：使用提前处理好的数组，避免WXML中使用map和箭头函数 -->
        <picker value="{{typeIndex}}" range="{{typeLabelList}}" bindchange="changeType">
          <view class="form-picker">
            <text>{{typeLabelList[typeIndex]}}</text>
            <image class="arrow-icon" src="/images/arrow-down.png" mode="widthFix"></image>
          </view>
        </picker>
      </view>
      <view class="form-item">
        <text class="form-label">次品数量(米)：<text class="required">*</text></text>
        <input class="form-input" type="number" placeholder="必填，输入次品数量" value="{{formData.quantity}}" bindinput="handleInput" data-key="quantity"></input>
      </view>
      <view class="form-item">
        <text class="form-label">损失金额(元)：<text class="required">*</text></text>
        <input class="form-input" type="number" placeholder="必填，输入损失金额" value="{{formData.lossAmount}}" bindinput="handleInput" data-key="lossAmount"></input>
      </view>
      <view class="form-item">
        <text class="form-label">次品描述：</text>
        <textarea class="form-textarea" placeholder="可选，描述次品问题" value="{{formData.description}}" bindinput="handleInput" data-key="description"></textarea>
      </view>
    </view>
    <view class="modal-actions">
      <button class="modal-btn cancel-btn" bindtap="closeAddModal">取消</button>
      <button class="modal-btn confirm-btn" bindtap="submitDefective">{{isEdit ? '保存修改' : '确认登记'}}</button>
    </view>
  </view>
</view>

<!-- 标记处理弹窗 -->
<view class="modal-mask" wx:if="{{showProcessModal}}" bindtap="closeProcessModal">
  <view class="modal-content" catchtap="stopPropagation">
    <view class="modal-title">标记次品处理</view>
    <view class="modal-info" wx:if="{{currentDefective}}">
      <view class="info-row">
        <text class="info-label">次品编号：</text>
        <text class="info-value">{{currentDefective.defectiveId}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">关联订单：</text>
        <text class="info-value">{{currentDefective.orderId || '无'}}</text>
      </view>
      <view class="form-item">
        <text class="form-label">处理方式：<text class="required">*</text></text>
        <input class="form-input" placeholder="输入处理方式（如：报废/返工/折价出售）" value="{{processData.method}}" bindinput="handleProcessInput" data-key="method"></input>
      </view>
      <view class="form-item">
        <text class="form-label">处理备注：</text>
        <textarea class="form-textarea" placeholder="可选，输入处理备注" value="{{processData.remark}}" bindinput="handleProcessInput" data-key="remark"></textarea>
      </view>
    </view>
    <view class="modal-actions">
      <button class="modal-btn cancel-btn" bindtap="closeProcessModal">取消</button>
      <button class="modal-btn confirm-btn" bindtap="confirmProcess">确认处理</button>
    </view>
  </view>
</view>